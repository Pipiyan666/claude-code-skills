<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>灵感胶囊</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- 权限说明（App Store 审核必填）-->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>灵感胶囊需要读取你的相册，自动识别截图并用本地 AI 提取知识。所有数据 100% 在你的 iPhone 上处理，绝不上传云端。</string>

    <key>NSCameraUsageDescription</key>
    <string>灵感胶囊需要相机权限，让你直接拍照保存灵感。</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>灵感胶囊需要麦克风权限，支持语音输入灵感（V2 功能）。</string>

    <!-- iOS 18+ Apple Intelligence 入口 -->
    <key>NSAppleEventsUsageDescription</key>
    <string>灵感胶囊使用 Apple Intelligence 进行本地 AI 分析。</string>

    <!-- 后台模式 -->
    <key>UIBackgroundModes</key>
    <array>
        <string>processing</string>
    </array>

    <!-- 最低 iOS 版本（FoundationModels 需要 iOS 26+）-->
    <key>MinimumOSVersion</key>
    <string>26.0</string>

    <!-- 启动配置 -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
    </dict>

    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string></string>
    </dict>
</dict>
</plist>
